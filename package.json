{
  "name": "smartpreco",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/supabase.gen.ts",
    "check:types-drift": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > /tmp/db-types-check.ts && diff src/types/supabase.gen.ts /tmp/db-types-check.ts",
    "check:react-types-major": "node scripts/check-react-types-major.mjs",
    "check:rate-limit-concurrency": "node scripts/check-rate-limit-concurrency.mjs",
    "check:gates": "pnpm check:react-types-major && pnpm check:rate-limit-concurrency"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@vercel/analytics": "^2.0.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^20.19.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
