# SmartPreço — Template de Variáveis de Ambiente
# Copie para .env.local e preencha com os valores reais

# ─────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────
# Obtenha as chaves em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Privado — NUNCA expor no cliente. Bypass de RLS para rotinas server-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Necessário no CI para `pnpm check:types-drift` (gerar tipos via supabase CLI).
SUPABASE_ACCESS_TOKEN=sbp_xxx
# ID do projeto Supabase — usado por `pnpm generate:types` e `pnpm check:types-drift`.
# Encontre em: https://supabase.com/dashboard/project/_/settings/general (campo "Reference ID")
# No CI, este valor deve ser configurado como GitHub Actions secret (Settings → Secrets → Actions).
SUPABASE_PROJECT_ID=your-supabase-project-id

# ─────────────────────────────────────────────────────────────────
# Sentry (observabilidade)
# ─────────────────────────────────────────────────────────────────
# DSN público — usado pelo cliente. Pode ser exposto.
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXXX
# DSN server/edge — mesmo valor é aceitável.
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXXX
# Org e project usados pelo wizard/CLI (upload de source maps no build).
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=smartpreco

# ─────────────────────────────────────────────────────────────────
# Mercado Livre (OAuth + busca)
# ─────────────────────────────────────────────────────────────────
# Crie a aplicação em: https://developers.mercadolivre.com.br/devcenter
ML_APP_ID=1234567890123456
ML_CLIENT_SECRET=your-ml-client-secret

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
