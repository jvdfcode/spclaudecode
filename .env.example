# SmartPreço — Template de Variáveis de Ambiente
# Copie para .env.local e preencha com os valores reais
# Obtenha as chaves em: https://supabase.com/dashboard/project/_/settings/api

# Supabase — público
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — privado (NUNCA expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
